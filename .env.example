# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Get this from your project's API settings (service_role key)
SUPABASE_SERVICE_ROLE_KEY=

# Creem.io Payment Configuration
CREEM_WEBHOOK_SECRET=
CREEM_API_KEY=
CREEM_API_URL=

# Site URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BASE_URL=localhost:3000

# Redirect success url after payment
CREEM_SUCCESS_URL=http://localhost:3000/dashboard

# AI Configuration for Chinese Name Generation
# Get your API key from OpenRouter (https://openrouter.ai/) or OpenAI
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Doubao TTS Configuration for Voice Playback
# Get these from Doubao/ByteDance TTS service
DOUBAO_TTS_APPID=
DOUBAO_TTS_ACCESS_TOKEN=

# Replicate Configuration for AI Landscape Design Generation
# Get your API token from https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Cloudflare R2 Configuration for image storage
# Get these from Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=landscape
# Public domain for the bucket (custom domain or the r2.dev public URL)
R2_PUBLIC_URL=

# Production Configuration (uncomment for production)
# CREEM_API_URL=https://api.creem.io
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# CREEM_SUCCESS_URL=https://yourdomain.com/dashboard
